{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jc-lightchecker-trigger",
  "main": "src/index.js",
  "compatibility_date": "2026-07-14",

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  "vars": {
    "GITHUB_OWNER": "tzhaya",
    "GITHUB_REPO": "jc-lightchecker",
    "GITHUB_WORKFLOW_FILE": "check.yml",
    "GITHUB_REF": "main"
  },

  "triggers": {
    "crons": [
      "7,22,37,52 * * * *"
    ]
  }
}
